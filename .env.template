# OAuth Token (for testing)
# Replace with your actual OAuth token: sk-ant-oat01-...
ANTHROPIC_OAUTH_TOKEN=YOUR_OAUTH_TOKEN_HERE

# Server Configuration
PORT=3000
HOST=localhost
NODE_ENV=development

# Optional: Override OAuth/API base URL
# ANTHROPIC_OAUTH_BASE_URL=https://api.anthropic.com

# Optional: Enable verbose logging
DEBUG=false

# Optional: Disable usage metrics
# DISABLE_TELEMETRY=1
# CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# Optional: Override OAuth client ID (for testing)
# ANTHROPIC_OAUTH_CLIENT_ID=
